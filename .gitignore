cat > .gitignore << 'EOF'
# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
*.py[cod]

# Model files (too big for git)
*.pt
*.pth
models/*.pt
models/*.pth

# Data files
data/train.txt
data/*.json

# Temporary files
*.swp
*.swo
*~

# OS files
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# IDE
.vscode/
.idea/
*.sublime-*

# Logs
*.log
files/claude_research_context.md
files/week7_kickoff.md

# Environment variables
.env
.env.local
.env.*.local
!.env.template

# Experiment outputs
src/transcript_*.txt
src/experiment_results.csv
debate_results.json
experiments/debate/
src/experiment_results.csv
!src/transcript_*.txt
